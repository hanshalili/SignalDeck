# ─────────────────────────────────────────────────────────────────────────────
# SignalDeck AI — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.
# All API keys are optional; the system falls back to mock data automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Storage backend ────────────────────────────────────────────────────────
# "sqlite"   — zero-config local storage (default, recommended for dev)
# "bigquery" — GCP BigQuery (production data warehouse)
STORAGE_BACKEND=sqlite

# ── SQLite ──────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/signaldeck.db

# ── BigQuery (only required when STORAGE_BACKEND=bigquery) ──────────────────
GCP_PROJECT_ID=
GCP_DATASET_ID=signaldeck
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Alpha Vantage — stocks + fundamentals ───────────────────────────────────
# Free tier: 25 req/day  |  https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── NewsAPI — financial news ─────────────────────────────────────────────────
# Free tier: 100 req/day  |  https://newsapi.org/register
NEWS_API_KEY=

# ── LLM providers (at least one required for AI analysis) ───────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Reddit OAuth2 (optional — public endpoints work without keys) ────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SignalDeck/1.0

# ── StockTwits (optional — raises rate limits) ──────────────────────────────
STOCKTWITS_ACCESS_TOKEN=

# ── Pipeline configuration ──────────────────────────────────────────────────
# Comma-separated list of ticker symbols to track
TICKERS=AAPL,MSFT,GOOGL,AMZN,META

# ── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Airflow ─────────────────────────────────────────────────────────────────
AIRFLOW_HOME=./airflow
# Override default credentials — required before any internet-accessible deployment
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_in_production
AIRFLOW_SECRET_KEY=change_me_in_production
